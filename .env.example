# Скопируй в .env и подставь реальные значения. Файл .env НЕ коммитится.
# Примеры ниже — иллюстрация формата, НЕ боевые значения.

# ============================================================
# СЕКРЕТЫ
# ============================================================

# Хеш пароля администратора (bcrypt/argon2, НЕ plaintext).
# Сгенерировать:
#   php -r "echo password_hash('d89#Pk1@T1', PASSWORD_DEFAULT).PHP_EOL;"
# Пример формата:
#   ADMIN_PASSWORD_HASH='$2y$12$abcdefghijklmnopqrstuvABCDEFGHIJKLMNOPQRSTUVWXYZ0123456'
ADMIN_PASSWORD_HASH=

# Секрет для подписи Bearer-токенов админки. ОТДЕЛЬНЫЙ от пароля — не переиспользуй.
# Сгенерировать:
#   php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
# Пример формата (64 hex):
#   TOKEN_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TOKEN_SECRET=

# Токен Telegram-бота (BotFather → /mybots → API Token).
# Формат: <цифры>:<строка из букв/цифр/подчёркиваний/дефисов>
# Пример:
#   BOT_TOKEN=1234567890:AAExampleTokenFromBotFatherReplaceMe_xyz
BOT_TOKEN=

# Секрет вебхука Telegram (fail-closed — без него bot.php отдаёт 500).
# Сгенерировать:
#   php -r "echo bin2hex(random_bytes(16)).PHP_EOL;"
# Потом зарегистрировать вебхук С ТЕМ ЖЕ секретом:
#   https://api.telegram.org/bot<BOT_TOKEN>/setWebhook?url=https://ragefill.by/bot.php&secret_token=<WEBHOOK_SECRET>
# Пример формата (32 hex):
#   WEBHOOK_SECRET=0123456789abcdef0123456789abcdef
WEBHOOK_SECRET=

# ============================================================
# ПУБЛИЧНЫЕ НАСТРОЙКИ
# ============================================================

# Базовый URL продакшена (без слеша на конце)
BASE_URL=https://ragefill.by

# Telegram-юзернейм для кнопки "Написать продавцу" (без @)
CONTACT_TELEGRAM=rage_fill

# ============================================================
# РЕЖИМ
# ============================================================

# true — показывать детали ошибок Slim (только для dev!)
# false — в продакшене всегда
DEBUG=false
